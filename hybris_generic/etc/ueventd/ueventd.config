# Vendor ueventd overlay for hybris_generic (Volla X23 / mimir).
#
# OHOS ueventd loads (in order, per ueventd_main.c:78-79):
#   /etc/ueventd.config              -> /system/etc/ueventd.config
#   /vendor/etc/ueventd.config       -> THIS FILE (vendor partition overlay)
#   /vendor/etc/ueventd_factory.config
#
# Native-boot needs vendor-overlay perms for nodes that the OHOS host expects
# to access on the libhybris path (Mali GPU, MTK DMA-BUF heaps, Halium DRM
# nodes the kernel exposes). These are granted via ueventd ownership.

[device]
# <device name> <mode> <uid> <gid> <parameter>

# Mali GPU (libhybris EGL/GLES path -> /system/lib64/libGLES_mali.so)
/dev/mali0                0666  graphics  graphics

# DMA-BUF heaps for Mali + composer cross-process buffer share (Phase 6.10E).
# `system` is the generic CPU-allocatable heap. The mtk_* heaps are MediaTek
# device-specific buffers used by HWC2 + Mali composition.
/dev/dma_heap/system      0666  graphics  graphics
/dev/dma_heap/mtk_mm      0666  graphics  graphics
/dev/dma_heap/mtk_mm-uncached  0666  graphics  graphics
/dev/dma_heap/mtk_prot    0666  graphics  graphics
/dev/dma_heap/mtk_sec     0666  graphics  graphics

# DRM render nodes already in /system/etc/ueventd.config (card0, renderD128).
# Re-asserting MTK-specific connector nodes in case the kernel build adds them.
/dev/dri/card0-DSI-0      0666  0          1003
/dev/dri/card1            0666  0          1003

# Input devices — Phase 7 needs CAP_DAC_OVERRIDE to open these O_RDWR;
# group ownership is android_input (gid 1004 in OHOS).
/dev/input/event*         0660  root       android_input
/dev/input/mice           0660  root       android_input
/dev/input/mouse*         0660  root       android_input

# WiFi/BT rfkill (Phase 10)
/dev/rfkill               0660  wifi       wifi

# ALSA — Phase 13B native audio adapter (libasound) needs r/w on every PCM node
/dev/snd/pcmC*D*p         0660  audio      audio
/dev/snd/pcmC*D*c         0660  audio      audio
/dev/snd/seq              0660  audio      audio
/dev/snd/timer            0660  audio      audio

# OHOS access_token_id (Phase 6.14) — already in /system/etc/ueventd.config
# but re-asserting here for vendor-partition first-boot resilience.
/dev/access_token_id      0666  access_token  access_token

# MT6789 ISP6s camera chardevs — Halium-side camerahalserver runs as
# cameraserver (Android uid 1047) in its own mount NS, which sees /dev shared
# from the OHOS host.  Android & OHOS user-namespaces don't overlap, so we
# need 0666 perms here — chowning to a named OHOS group doesn't grant access
# to Halium uids.  See phase_n12_camera_modulemap.md for the kernel-module map.
/dev/camera-isp           0666  root       root
/dev/camera-mem           0666  root       root
/dev/camera-rsc           0666  root       root
/dev/camera-dip           0666  root       root
/dev/camera-mfb           0666  root       root
/dev/camera-wpe           0666  root       root
/dev/camera-dpe           0666  root       root
/dev/camera-pda           0666  root       root
/dev/kd_camera_hw         0666  root       root
/dev/seninf               0666  root       root
/dev/flashlight           0666  root       root

# Power supply class (battery, charger) — read by OHOS battery service.
# These are in /sys/class/power_supply/, not /dev/, so ueventd doesn't apply;
# noted here for visibility. Verified accessible to system uid by default.

# USB DRD (Phase N7) — UDC node "musb-hdrc" handled by configfs; no /dev/ entry.
