From dc51b96d776bc96861d0c48b511cc4245ae02e57 Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Thu, 28 May 2026 11:59:23 +0200
Subject: [PATCH] power_manager: disable screen timeout

Keep the screen on indefinitely on dev/emulator builds. Avoids surprise lock-screen during interactive testing where the device sees no input for tens of seconds.

Change-Id: I86fe5447402336223106bc39fc7f121ed3c76742
Signed-off-by: Francesco Pham <francesco.pham1@h-partners.com>
---
 services/native/include/power_state_machine.h | 2 +-
 services/native/profile/power_mode_config.xml | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/services/native/include/power_state_machine.h b/services/native/include/power_state_machine.h
index 55d1e7d3..b1938878 100644
--- a/services/native/include/power_state_machine.h
+++ b/services/native/include/power_state_machine.h
@@ -107,7 +107,7 @@ public:
     static constexpr int32_t DEFAULT_DC_DISPLAY_OFF_TIME_MS = 300000
     static constexpr int32_t DEFAULT_DISPLAY_OFF_TIME_MS = DEFAULT_DC_DISPLAY_OFF_TIME_MS;
 #else
-    static constexpr int32_t DEFAULT_DISPLAY_OFF_TIME_MS = 30000;
+    static constexpr int32_t DEFAULT_DISPLAY_OFF_TIME_MS = -1;
 #endif
     static constexpr int32_t DEFAULT_SLEEP_TIME_MS = 5000;
     static constexpr int64_t OFF_TIMEOUT_FACTOR = 5;
diff --git a/services/native/profile/power_mode_config.xml b/services/native/profile/power_mode_config.xml
index f4fcfcbc..9d507121 100644
--- a/services/native/profile/power_mode_config.xml
+++ b/services/native/profile/power_mode_config.xml
@@ -34,7 +34,7 @@
 -->
 <switch_proxy version="1">
     <proxy id="600">
-        <switch id="101" value="30000" recover_flag="0"/>
+        <switch id="101" value="-1" recover_flag="0"/>
         <switch id="102" value="0" recover_flag="0"/>
         <switch id="103" value="-1" recover_flag="0"/>
         <switch id="107" value="1" recover_flag="0"/>
-- 
2.43.0

