@@ -147,11 +140,13 @@ void* Zone::_alloc(size_t size, size_t alignment) noexcept {
   if (ASMJIT_UNLIKELY(newSize > SIZE_MAX - kBlockSize - blockAlignmentOverhead))
     return nullptr;
 
+  ASSERT(_pandaAllocator != nullptr);
