 src/asmjit/core/codeholder.cpp | 23 ++++++++++++++---------
 src/asmjit/core/codeholder.h   |  6 +++++-
 src/asmjit/core/radefs_p.h     |  2 +-
 src/asmjit/core/string.h       |  2 +-
