diff --git a/build.sh b/build.sh
index 442163704..b4bcceb9a 100755
--- a/build.sh
+++ b/build.sh
@@ -52,6 +52,18 @@ if [ "$CPU" == "arm" ]; then
       --disable-neon
 fi
 
+if [ "$CPU" == "x86_64" ]; then
+  ./configure \
+      --target=generic-gnu \
+      --enable-vp9-highbitdepth \
+      --disable-vp8-encoder \
+      --disable-vp9-encoder \
+      --disable-unit-tests   \
+      --disable-examples \
+      --disable-libyuv  \
+      --disable-webm-io
+fi
+
 sed -i 's/#define HAVE_NEON[[:space:]]*0/#define HAVE_NEON 1/' vpx_config.h
 sed -i 's/#define CONFIG_INSTALL_DOCS[[:space:]]*1/#define CONFIG_INSTALL_DOCS 0/' vpx_config.h
 sed -i 's/#define HAVE_NEON_DOTPROD[[:space:]]*1/#define HAVE_NEON_DOTPROD 0/' vpx_config.h
@@ -64,3 +76,14 @@ sed -i 's/#define CONFIG_RUNTIME_CPU_DETECT[[:space:]]*1/#define CONFIG_RUNTIME_
 
 cp vpx_config.h "$OUTPUT_DIR/"
 rm -f vpx_config.h
+
+# For x86_64, copy the configure-generated rtcd headers to output dir.
+# For arm64/arm, pre-generated headers in armv8_config/armv7_config are used instead.
+if [ "$CPU" == "x86_64" ]; then
+  for rtcd_header in vp8_rtcd.h vp9_rtcd.h vpx_dsp_rtcd.h vpx_scale_rtcd.h; do
+    if [ -f "$rtcd_header" ]; then
+      cp "$rtcd_header" "$OUTPUT_DIR/"
+      rm -f "$rtcd_header"
+    fi
+  done
+fi
