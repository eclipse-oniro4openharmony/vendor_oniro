-# Attempt to download the file using curl, retrying once if it fails for a
-# partial file (18).
-$(LIBVPX_TEST_DATA): $(SRC_PATH_BARE)/test/test-data.sha1
-	@echo "    [DOWNLOAD] $@"
-	$(qexec)( \
-	  trap 'rm -f $@' INT TERM; \
-	  curl="curl -S -s --retry 1 -L -o $@ $(call libvpx_test_data_url,$(@F))"; \
-	  $$curl; ret=$$?; \
-	  case "$$ret" in \
-	    18) $$curl -C - ;; \
-	    *) exit $$ret ;; \
-	  esac \
-	)
