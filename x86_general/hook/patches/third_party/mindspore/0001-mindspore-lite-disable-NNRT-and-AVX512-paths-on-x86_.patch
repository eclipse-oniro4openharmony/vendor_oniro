From b93556e7e27bf0eb37b51d1900783d780a034fc1 Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Thu, 28 May 2026 11:59:30 +0200
Subject: [PATCH] mindspore-lite: disable NNRT and AVX512 paths on x86_general

x86_general does not ship NNRT, and the AVX512 paths require CPU support absent on QEMU. Mirror the existing is_emulator gates so the build does not attempt to compile those sources.

Change-Id: I8daa68f747c02f759ae034a7d6318f73bcbbec5a
Signed-off-by: Francesco Pham <francesco.pham1@h-partners.com>
---
 mindspore-src/source/mindspore-lite/BUILD.gn                    | 2 +-
 .../source/mindspore-lite/src/litert/kernel/cpu/BUILD.gn        | 2 +-
 .../mindspore-lite/src/litert/kernel/cpu/nnacl_c/BUILD.gn       | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/mindspore-src/source/mindspore-lite/BUILD.gn b/mindspore-src/source/mindspore-lite/BUILD.gn
index 916893fb..b8be5139 100644
--- a/mindspore-src/source/mindspore-lite/BUILD.gn
+++ b/mindspore-src/source/mindspore-lite/BUILD.gn
@@ -349,7 +349,7 @@ missing_sources = [
 all_sources += missing_sources
 SUPPORT_NNRT = false
 # currently, only arm/arm64 real machine support nnrt
-if ((target_cpu == "arm" || target_cpu == "arm64") && !is_emulator) {
+if ((target_cpu == "arm" || target_cpu == "arm64") && !is_emulator && product_name != "x86_general") {
   SUPPORT_NNRT = true
 }
 
diff --git a/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/BUILD.gn b/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/BUILD.gn
index 5d591675..bc492e4d 100644
--- a/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/BUILD.gn
+++ b/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/BUILD.gn
@@ -250,7 +250,7 @@ control_kernel_sources = [
 ]
 
 # emulator not support avx512
-if (!is_emulator) {
+if (!is_emulator && product_name != "x86_general") {
   cpu_kernel_sources += [
     "fp32/convolution_im2col_avx512_fp32.cc",
     "fp32/matmul_fp32_avx512.cc",
diff --git a/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/nnacl_c/BUILD.gn b/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/nnacl_c/BUILD.gn
index 9a9b28fd..1e65b8cc 100644
--- a/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/nnacl_c/BUILD.gn
+++ b/mindspore-src/source/mindspore-lite/src/litert/kernel/cpu/nnacl_c/BUILD.gn
@@ -922,7 +922,7 @@ arm64_only_sources += arm64_fp32_kernel_sources
 x86_64_only_sources = sse_avx_avx512_sources
 x86_64_only_sources += avx_fp32_kernel_sources
 # emulator not support avx512
-if (is_emulator) {
+if (is_emulator || product_name == "x86_general") {
   not_needed(avx512_fp32_kernel_sources)
   not_needed(gemm_avx512_kernel_sources)
   not_needed(gemm_mask_avx512_kernel_sources)
-- 
2.43.0

