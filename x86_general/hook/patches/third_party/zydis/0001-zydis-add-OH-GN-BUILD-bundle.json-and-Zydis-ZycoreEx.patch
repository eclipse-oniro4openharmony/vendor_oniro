+}
diff --git a/include/ZycoreExportConfig.h b/include/ZycoreExportConfig.h
new file mode 100644
index 0000000..f71faf5
--- /dev/null
+++ b/include/ZycoreExportConfig.h
@@ -0,0 +1,19 @@
+/*
+ * Shim for the CMake-generated ZycoreExportConfig.h.
+ *
+ * Upstream zycore-c uses CMake's generate_export_header() to produce this
+ * file, which #defines ZYCORE_EXPORT to the appropriate dllexport/visibility
+ * macro. OpenHarmony builds zycore as a static library via GN and never runs
+ * CMake, so we ship this stub instead. ZYCORE_EXPORT expands to nothing,
+ * matching ZYCORE_STATIC_DEFINE behaviour.
+ */
+
+#ifndef ZYCORE_EXPORT_CONFIG_H
+#define ZYCORE_EXPORT_CONFIG_H
+
+#define ZYCORE_EXPORT
+#define ZYCORE_NO_EXPORT
+#define ZYCORE_DEPRECATED_EXPORT
+#define ZYCORE_DEPRECATED_NO_EXPORT
+
+#endif /* ZYCORE_EXPORT_CONFIG_H */
diff --git a/include/ZydisExportConfig.h b/include/ZydisExportConfig.h
new file mode 100644
index 0000000..dcf2365
--- /dev/null
+++ b/include/ZydisExportConfig.h
@@ -0,0 +1,19 @@
+/*
+ * Shim for the CMake-generated ZydisExportConfig.h.
+ *
+ * Upstream Zydis uses CMake's generate_export_header() to produce this file,
+ * which #defines ZYDIS_EXPORT to the appropriate dllexport/visibility macro.
+ * OpenHarmony builds Zydis as a static library via GN and never runs CMake,
+ * so we ship this stub instead. All ZYDIS_* visibility macros expand to
+ * nothing, matching ZYDIS_STATIC_DEFINE behaviour.
+ */
+
+#ifndef ZYDIS_EXPORT_CONFIG_H
+#define ZYDIS_EXPORT_CONFIG_H
+
+#define ZYDIS_EXPORT
+#define ZYDIS_NO_EXPORT
+#define ZYDIS_DEPRECATED_EXPORT
+#define ZYDIS_DEPRECATED_NO_EXPORT
+
+#endif /* ZYDIS_EXPORT_CONFIG_H */
-- 
