From ff222ac3343561e0f4e30b0b318140a63c6365fa Mon Sep 17 00:00:00 2001
From: Francesco Pham <francesco.pham1@h-partners.com>
Date: Thu, 28 May 2026 12:00:17 +0200
Subject: [PATCH 1/2] deps_guard: alias ld-musl-{arm,aarch64,x86_64,riscv64}
 loader names

The ld-musl loader GN target is historically named 'ld-musl-arm.so.1' but produces an arch-specific file (ld-musl-x86_64.so.1, ld-musl-aarch64.so.1, ld-musl-riscv64.so.1). Whitelist entries refer to the historical name only, so on non-arm builds every system whitelist row missed the actual loader and 300+ false-positive deps_guard errors fired. Aliasing the four arches lets one entry cover all four.

Change-Id: I36edc9fa1b5cdfd36471428894156303cbc2b1a8
Signed-off-by: Francesco Pham <francesco.pham1@h-partners.com>
---
 tools/deps_guard/rules_checker/base_rule.py | 19 ++++++++++++++++---
 1 file changed, 16 insertions(+), 3 deletions(-)

diff --git a/tools/deps_guard/rules_checker/base_rule.py b/tools/deps_guard/rules_checker/base_rule.py
index 4ea6766..a6a0ae5 100755
--- a/tools/deps_guard/rules_checker/base_rule.py
+++ b/tools/deps_guard/rules_checker/base_rule.py
@@ -114,12 +114,25 @@ class BaseRule(object):
             if not contents:
                 self.log("****system/vendor only whitelist.json {} is null****".format(whitelist_file))
             json_data = json.loads(contents)
+            # The ld-musl loader GN target is named "ld-musl-arm.so.1" for
+            # historical reasons but produces an arch-specific file
+            # (ld-musl-x86_64.so.1, ld-musl-aarch64.so.1, ld-musl-riscv64.so.1).
+            # Treat all four as equivalent so a single whitelist entry covers
+            # every supported arch.
+            musl_loaders = {
+                "ld-musl-arm.so.1",
+                "ld-musl-aarch64.so.1",
+                "ld-musl-x86_64.so.1",
+                "ld-musl-riscv64.so.1",
+            }
             for so in json_data:
                 so_file_name = so.get("so_file_name")
                 dep_file_name = so.get("dep_file_name")
-                so_dict = {so_file_name: dep_file_name}
-                if so_dict not in res:
-                    res.append(so_dict)
+                dep_names = {dep_file_name} | (musl_loaders if dep_file_name in musl_loaders else set())
+                for name in dep_names:
+                    so_dict = {so_file_name: name}
+                    if so_dict not in res:
+                        res.append(so_dict)
 
         return res
 
